# SFTP upload settings for release/build-zip.command.
#
# Copy this file to release/deploy.env (which is gitignored) and fill in your values.
# release/build-zip.command reads it to upload the built zip to the wp-update-server.
# Never commit release/deploy.env — it holds host/credential details.
#
# Plugin identity is configured at the top of release/build-zip.command:
# PLUGIN_ROOT, PLUGIN_FILE, SLUG, and DEFAULT_METADATA_URL. Change those when
# copying this workflow to another plugin repo, and keep them aligned with the
# updater class.

# --- Connection --------------------------------------------------------------
DEPLOY_HOST="35.224.70.159"            # SSH/SFTP hostname
DEPLOY_USER="omegabenefitsnet"
DEPLOY_PORT="58288"                    # default 22

# --- Authentication (pick ONE) ----------------------------------------------
# Preferred: an SSH private key. Leave DEPLOY_PASS unset/commented if you use this.
DEPLOY_SSH_KEY="$HOME/.ssh/id_ed25519"
# Fallback: password auth. Requires `sshpass` installed locally
# (brew install hudochenkov/sshpass/sshpass). Comment out DEPLOY_SSH_KEY if used.
# DEPLOY_PASS="your-password"

# --- Remote destination ------------------------------------------------------
# Absolute path to the wp-update-server packages directory on the server.
DEPLOY_REMOTE_DIR="/home/your-sftp-user/wp-update-server/packages"
# wp-update-server serves <slug>.zip and reads the version from inside it, so
# keep this as the unversioned slug filename (overwrites on each upload).
DEPLOY_REMOTE_FILENAME="omega-network-admin.zip"

# Optional: override the metadata URL from release/build-zip.command for this
# machine/deployment target.
#DEPLOY_METADATA_URL="https://omegabenefits.net/wp-update-server/?action=get_metadata&slug=omega-network-admin"
